# For local dev — uses a local SQLite file
DATABASE_URL="file:local.db"

# NextAuth secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# For production (Turso) — sign up at turso.tech (free) and create a database
# DATABASE_URL="libsql://your-db.turso.io"
# DATABASE_AUTH_TOKEN="your-token"

# Vercel Blob — get from your Vercel project's Storage tab
BLOB_READ_WRITE_TOKEN=

# SMTP — for password resets, room invites, and weekly low-stock digest
# Gmail: enable 2FA, then create an App Password (myaccount.google.com/apppasswords).
# Other providers (SES, Mailgun, etc.) work too — just point SMTP_HOST at them.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From address — must match SMTP_USER for Gmail; display name is up to you.
EMAIL_FROM="Pantry <pantryapp@gmail.com>"
# Public URL of this app — used in email links
APP_URL="http://localhost:3000"
# Secret for the cron endpoint (any random string). Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>` automatically.
CRON_SECRET=
