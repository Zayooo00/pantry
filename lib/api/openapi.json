{
  "openapi": "3.0.0",
  "info": {
    "title": "Pantry API",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "schemas": {
      "SidebarRoom": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "glyph": {
            "type": "string"
          },
          "count": {
            "type": "number"
          },
          "low": {
            "type": "number"
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "editor",
              "viewer"
            ]
          }
        },
        "required": [
          "id",
          "name",
          "glyph",
          "count",
          "low",
          "role"
        ]
      },
      "SidebarResponse": {
        "type": "object",
        "properties": {
          "rooms": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SidebarRoom"
            }
          },
          "shoppingCount": {
            "type": "number"
          }
        },
        "required": [
          "rooms",
          "shoppingCount"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "nullable": true
          }
        }
      },
      "CreateRoomResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      },
      "CreateRoomRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "glyph": {
            "type": "string",
            "minLength": 1
          },
          "subtitle": {
            "type": "string",
            "nullable": true
          },
          "tinted": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "glyph"
        ]
      },
      "OkResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          }
        },
        "required": [
          "ok"
        ]
      },
      "PatchRoomRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "glyph": {
            "type": "string"
          },
          "subtitle": {
            "type": "string",
            "nullable": true
          },
          "tinted": {
            "type": "boolean"
          },
          "archived": {
            "type": "boolean"
          }
        }
      },
      "ReorderRoomsRequest": {
        "type": "object",
        "properties": {
          "order": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        },
        "required": [
          "order"
        ]
      },
      "Member": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "viewer",
              "editor"
            ]
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "userId",
          "name",
          "email",
          "role",
          "createdAt"
        ]
      },
      "MembersResponse": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "object",
            "nullable": true,
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "email": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "name",
              "email"
            ]
          },
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Member"
            }
          },
          "isOwner": {
            "type": "boolean"
          }
        },
        "required": [
          "owner",
          "members",
          "isOwner"
        ]
      },
      "InviteMemberAdded": {
        "type": "object",
        "properties": {
          "member": {
            "type": "object",
            "properties": {
              "userId": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "enum": [
                  "viewer",
                  "editor"
                ]
              }
            },
            "required": [
              "userId",
              "name",
              "email",
              "role"
            ]
          }
        },
        "required": [
          "member"
        ]
      },
      "InviteMemberPending": {
        "type": "object",
        "properties": {
          "pending": {
            "type": "object",
            "properties": {
              "email": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "enum": [
                  "viewer",
                  "editor"
                ]
              }
            },
            "required": [
              "email",
              "role"
            ]
          }
        },
        "required": [
          "pending"
        ]
      },
      "InviteMemberResponse": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/InviteMemberAdded"
          },
          {
            "$ref": "#/components/schemas/InviteMemberPending"
          }
        ]
      },
      "InviteMemberRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": [
              "viewer",
              "editor"
            ]
          }
        },
        "required": [
          "email",
          "role"
        ]
      },
      "PatchMemberRequest": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "viewer",
              "editor"
            ]
          }
        },
        "required": [
          "role"
        ]
      },
      "CreateItemResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      },
      "CreateItemRequest": {
        "type": "object",
        "properties": {
          "roomId": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "brand": {
            "type": "string",
            "nullable": true
          },
          "category": {
            "type": "string",
            "nullable": true
          },
          "unit": {
            "type": "string",
            "minLength": 1
          },
          "count": {
            "type": "number",
            "nullable": true
          },
          "threshold": {
            "type": "number",
            "nullable": true
          },
          "reorderAmount": {
            "type": "number",
            "nullable": true
          },
          "shelf": {
            "type": "string",
            "nullable": true
          },
          "expiresAt": {
            "type": "string",
            "nullable": true
          },
          "openedAt": {
            "type": "string",
            "nullable": true
          },
          "purchasedAt": {
            "type": "string",
            "nullable": true
          },
          "lastPrice": {
            "type": "number",
            "nullable": true
          },
          "barcode": {
            "type": "string",
            "nullable": true
          },
          "notes": {
            "type": "string",
            "nullable": true
          },
          "tags": {
            "type": "string",
            "nullable": true
          },
          "photoUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          }
        },
        "required": [
          "roomId",
          "name",
          "unit",
          "count"
        ]
      },
      "PatchItemRequest": {
        "type": "object",
        "properties": {
          "count": {
            "type": "number",
            "nullable": true
          },
          "name": {
            "type": "string"
          },
          "brand": {
            "type": "string",
            "nullable": true
          },
          "category": {
            "type": "string",
            "nullable": true
          },
          "unit": {
            "type": "string"
          },
          "threshold": {
            "type": "number",
            "nullable": true
          },
          "reorderAmount": {
            "type": "number",
            "nullable": true
          },
          "shelf": {
            "type": "string",
            "nullable": true
          },
          "expiresAt": {
            "type": "string",
            "nullable": true
          },
          "openedAt": {
            "type": "string",
            "nullable": true
          },
          "purchasedAt": {
            "type": "string",
            "nullable": true
          },
          "lastPrice": {
            "type": "number",
            "nullable": true
          },
          "barcode": {
            "type": "string",
            "nullable": true
          },
          "notes": {
            "type": "string",
            "nullable": true
          },
          "tags": {
            "type": "string",
            "nullable": true
          },
          "roomId": {
            "type": "string"
          },
          "photoUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          }
        }
      },
      "ShoppingPostResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      },
      "ManualShoppingRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "quantity": {
            "type": "number",
            "nullable": true
          },
          "unit": {
            "type": "string",
            "minLength": 1
          },
          "groupName": {
            "type": "string",
            "nullable": true
          },
          "reason": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "name",
          "quantity",
          "unit"
        ]
      },
      "FromItemShoppingRequest": {
        "type": "object",
        "properties": {
          "itemId": {
            "type": "string"
          }
        },
        "required": [
          "itemId"
        ]
      },
      "ShoppingPostRequest": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/ManualShoppingRequest"
          },
          {
            "$ref": "#/components/schemas/FromItemShoppingRequest"
          }
        ]
      },
      "PatchShoppingRequest": {
        "type": "object",
        "properties": {
          "done": {
            "type": "boolean"
          },
          "quantity": {
            "type": "number",
            "nullable": true
          }
        }
      },
      "ActivityEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "delta": {
            "type": "number",
            "nullable": true
          },
          "countAfter": {
            "type": "number",
            "nullable": true
          },
          "note": {
            "type": "string",
            "nullable": true
          },
          "actor": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string"
          },
          "itemId": {
            "type": "string",
            "nullable": true
          },
          "itemName": {
            "type": "string",
            "nullable": true
          },
          "unit": {
            "type": "string",
            "nullable": true
          },
          "roomId": {
            "type": "string",
            "nullable": true
          },
          "roomName": {
            "type": "string",
            "nullable": true
          },
          "roomGlyph": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "kind",
          "delta",
          "countAfter",
          "note",
          "actor",
          "createdAt",
          "itemId",
          "itemName",
          "unit",
          "roomId",
          "roomName",
          "roomGlyph"
        ]
      },
      "ActivityResponse": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ActivityEvent"
            }
          }
        },
        "required": [
          "events"
        ]
      },
      "SearchItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "roomId": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "name",
          "roomId",
          "category"
        ]
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchItem"
            }
          }
        },
        "required": [
          "items"
        ]
      },
      "PatchMeRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "email": {
            "type": "string",
            "maxLength": 160,
            "format": "email"
          },
          "currentPassword": {
            "type": "string"
          },
          "newPassword": {
            "type": "string",
            "minLength": 8,
            "maxLength": 200
          },
          "notifyDigest": {
            "type": "string",
            "enum": [
              "off",
              "daily",
              "weekly"
            ]
          }
        }
      },
      "SharedWithMeRoom": {
        "type": "object",
        "properties": {
          "roomId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "glyph": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "viewer",
              "editor"
            ]
          },
          "ownerName": {
            "type": "string"
          },
          "ownerEmail": {
            "type": "string"
          }
        },
        "required": [
          "roomId",
          "name",
          "glyph",
          "role",
          "ownerName",
          "ownerEmail"
        ]
      },
      "IShareEntry": {
        "type": "object",
        "properties": {
          "roomId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "glyph": {
            "type": "string"
          },
          "members": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "userId": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "role": {
                  "type": "string",
                  "enum": [
                    "viewer",
                    "editor"
                  ]
                }
              },
              "required": [
                "userId",
                "name",
                "email",
                "role"
              ]
            }
          }
        },
        "required": [
          "roomId",
          "name",
          "glyph",
          "members"
        ]
      },
      "MeSharedResponse": {
        "type": "object",
        "properties": {
          "sharedWithMe": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SharedWithMeRoom"
            }
          },
          "iShare": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IShareEntry"
            }
          }
        },
        "required": [
          "sharedWithMe",
          "iShare"
        ]
      },
      "SignUpRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "maxLength": 160,
            "format": "email"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "maxLength": 200
          }
        },
        "required": [
          "email",
          "name",
          "password"
        ]
      },
      "UploadResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/sidebar": {
      "get": {
        "responses": {
          "200": {
            "description": "Sidebar data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SidebarResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/rooms": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRoomRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Room created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateRoomResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/rooms/{id}": {
      "patch": {
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatchRoomRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Has items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/rooms/reorder": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReorderRoomsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reordered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/rooms/{id}/members": {
      "get": {
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Members",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MembersResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InviteMemberRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invited or pending",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InviteMemberResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
