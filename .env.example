# For local dev — uses a local SQLite file
DATABASE_URL="file:local.db"

# NextAuth secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# For production (Turso) — sign up at turso.tech (free) and create a database
# DATABASE_URL="libsql://your-db.turso.io"
# DATABASE_AUTH_TOKEN="your-token"

# Vercel Blob — get from your Vercel project's Storage tab
BLOB_READ_WRITE_TOKEN=

# Resend — for password resets, room invites, and weekly low-stock digest
# Get an API key at resend.com (free tier: 100 emails/day)
RESEND_API_KEY=
# From address — must be a verified sender on your Resend domain
EMAIL_FROM="Pantry <pantry@yourdomain.com>"
# Public URL of this app — used in email links
APP_URL="http://localhost:3000"
# Secret for the cron endpoint (any random string). Set the same value in Vercel
# Cron headers, or call the endpoint with `?secret=...`.
CRON_SECRET=
